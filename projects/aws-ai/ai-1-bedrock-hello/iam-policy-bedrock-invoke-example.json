{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowInvokeSpecificBedrockModel",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": "arn:aws:bedrock:eu-central-1::foundation-model/REPLACE_WITH_MODEL_ID"
    },
    {
      "Sid": "AllowListFoundationModelsForLearning",
      "Effect": "Allow",
      "Action": [
        "bedrock:ListFoundationModels",
        "bedrock:GetFoundationModel"
      ],
      "Resource": "*"
    }
  ]
}
